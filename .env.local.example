# ─── API Keys ─────────────────────────────────────────────────────────────────

# AirKorea 에어코리아 API (data.go.kr, 무료 — 공공데이터포털 가입 필요)
# https://www.data.go.kr/data/15073861/openapi.do
AIRKOREA_API_KEY=

# 기상청 꽃가루농도위험지수 (data.go.kr, 무료 — 공공데이터포털 가입 필요)
# https://www.data.go.kr/ → HealthWthrIdxServiceV3
KMA_POLLEN_API_KEY=

# ─── Open-Meteo (꽃가루, 해외 fallback) ──────────────────────────────────────
# No API key required. Uses CAMS model, Europe only for pollen.
# https://open-meteo.com/en/docs/air-quality-api

# ─── Upstash Redis (optional — in-memory cache used if not set) ───────────────
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
